# {{ project_name }} - Automated Engineering Reports
# Generated by konflux-devlake-mcp scaffold-report-repo skill
#
# SCHEDULER_TYPE variable controls which reports run:
{%- for category in categories %}
#   - "{{ category.key }}": {{ category.name }} only
{%- endfor %}
#   - "dora_all": DORA + Engineering Excellence + PR Cycle Time
#   - "all" or not set: All reports (default)

default:
  tags:
    - "{{ runner_tags }}"
  interruptible: true
  retry:
    max: 1
    when:
      - runner_system_failure
      - stuck_or_timeout_failure

stages:
  - trigger
  - publish

variables:
  AI_PROVIDER: "{{ ai_provider }}"
  # ANALYSIS_DAYS: "30"  # Override via schedule/pipeline variables

include:
  - local: '.gitlab/workflows/scheduled-analysis.yml'
  - local: '.gitlab/workflows/pages-deployment.yml'

workflow:
  rules:
    - if: $CI_PIPELINE_SOURCE == "schedule"
    - if: $CI_PIPELINE_SOURCE == "web"
    - if: $CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH
    - if: $CI_COMMIT_BRANCH
      when: never
