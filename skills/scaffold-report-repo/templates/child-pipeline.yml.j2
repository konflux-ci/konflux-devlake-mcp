# {{ category.name }} Child Pipeline
# Generated by konflux-devlake-mcp scaffold-report-repo skill

stages:
  - analysis

include:
{% if include_method == 'remote' %}
  - remote: 'https://raw.githubusercontent.com/redhat-community-ai-tools/cicaddy-gitlab/{{ cicaddy_gitlab_version }}/gitlab/ai_cron_template.yml'
{% elif include_method == 'project' %}
  - project: '{{ gitlab_project_path }}'
    file: 'gitlab/ai_cron_template.yml'
    ref: '{{ cicaddy_gitlab_version }}'
{% endif %}
  - local: '.gitlab/templates/mcp/devlake.yml'
{% if ca_cert_url %}
  - local: '.gitlab/templates/base/ssl_setup.yml'
{% endif %}

# Base job configuration for {{ category.name }}
.{{ category.key }}_base:
  extends:
    - .ai_cron_template
    - .mcp_devlake
{% if ca_cert_url %}
    - .ssl_setup
{% endif %}
  stage: analysis
  tags:
    - "{{ runner_tags }}"
  variables:
    AI_PROVIDER: "{{ ai_provider }}"
    AI_MODEL: "{{ ai_model }}"
    CRON_TASK_TYPE: "custom"
    CRON_SCOPE: "external_tools"
    MCP_SERVERS_CONFIG: "[$MCP_DEVLAKE_CONFIG]"
    ENABLE_LOCAL_TOOLS: "true"
    LOCAL_TOOLS_WORKING_DIR: ".."
    REPORT_TEMPLATE_PATH: ".gitlab/report-template.html"
    ANALYSIS_DAYS: "${ANALYSIS_DAYS:-30}"
    MAX_INFER_ITERS: "40"
    MAX_EXECUTION_TIME: "${MAX_EXECUTION_TIME:-1800}"
    CONTEXT_SAFETY_FACTOR: "${CONTEXT_SAFETY_FACTOR:-0.9}"
{% if slack_enabled %}
    SLACK_ENABLED: "true"
    SLACK_WEBHOOK_URL: $SLACK_WEBHOOK_URL
{% endif %}
  artifacts:
    paths:
      - "task_*.html"
      - "task_*.json"
      - "*_ai_direct_resp.html"
    expire_in: 30 days
    when: always
  rules:
    - if: $CI_PIPELINE_SOURCE == "parent_pipeline"
    - if: $CI_PIPELINE_SOURCE == "web"
      when: manual
  timeout: 2h

{% if pipeline_structure in ['org', 'both'] %}
# Org-level {{ category.name }} analysis
{{ category.key }}_org:
  extends: .{{ category.key }}_base
  variables:
    AI_TASK_FILE: "../.gitlab/prompts/{{ category.prompt_dir }}/{{ category.task_file }}"
    DEVLAKE_PROJECT_NAME: "{{ org_project_name }}"
{% endif %}

{% if pipeline_structure in ['subgroup', 'both'] %}
{% for team in teams %}
# {{ team.name }} - {{ category.name }} analysis
{{ category.key }}_{{ team.key }}:
  extends: .{{ category.key }}_base
  variables:
    AI_TASK_FILE: "../.gitlab/prompts/{{ category.prompt_dir }}/{{ category.subgroup_task_file | default(category.task_file) }}"
    DEVLAKE_PROJECT_NAME: "{{ team.project_name }}"
    TEAM_NAME: "{{ team.name }}"
{% endfor %}
{% endif %}
